{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uctovnik.local/schemas/accountant-export.schema.json",
  "title": "Accountant monthly export",
  "type": "object",
  "additionalProperties": false,
  "required": ["exportPackage", "manifest", "hashes"],
  "properties": {
    "exportPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "organizationId",
        "periodId",
        "periodKey",
        "status",
        "zipFileId",
        "zipHash",
        "manifestHash",
        "createdBy",
        "createdAt"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "organizationId": { "type": "string", "format": "uuid" },
        "periodId": { "type": "string", "format": "uuid" },
        "periodKey": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
        },
        "status": {
          "type": "string",
          "enum": ["prepared", "exported", "downloaded", "accepted_by_accountant", "changed_after_export", "locked"]
        },
        "zipFileId": { "type": "string", "format": "uuid" },
        "zipHash": { "$ref": "#/$defs/sha256" },
        "manifestHash": { "$ref": "#/$defs/sha256" },
        "documentCounts": { "$ref": "#/$defs/documentCounts" },
        "createdBy": { "type": "string", "format": "uuid" },
        "createdAt": { "type": "string", "format": "date-time" },
        "downloadedAt": { "type": ["string", "null"], "format": "date-time" },
        "acceptedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["organizationId", "periodKey", "createdAt", "createdBy", "files", "includedDocuments"],
      "properties": {
        "organizationId": { "type": "string", "format": "uuid" },
        "organizationName": { "type": ["string", "null"], "maxLength": 190 },
        "periodKey": {
          "type": "string",
          "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])$"
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string", "format": "uuid" },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/exportFile" }
        },
        "includedDocuments": {
          "type": "array",
          "items": { "$ref": "#/$defs/includedDocument" }
        },
        "filters": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "includeIssuedInvoices": { "type": "boolean", "default": true },
            "includeReceivedInvoices": { "type": "boolean", "default": true },
            "includeBankTransactions": { "type": "boolean", "default": true },
            "includeVatSummary": { "type": "boolean", "default": true }
          }
        }
      }
    },
    "hashes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 500 },
          "sha256": { "$ref": "#/$defs/sha256" }
        }
      }
    },
    "auditSummary": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["exportId", "createdBy", "createdAt", "documentCounts", "zipHash", "manifestHash"],
      "properties": {
        "exportId": { "type": "string", "format": "uuid" },
        "createdBy": { "type": "string", "format": "uuid" },
        "createdAt": { "type": "string", "format": "date-time" },
        "documentCounts": { "$ref": "#/$defs/documentCounts" },
        "zipHash": { "$ref": "#/$defs/sha256" },
        "manifestHash": { "$ref": "#/$defs/sha256" },
        "changedDocumentsAfterExport": {
          "type": "array",
          "items": { "$ref": "#/$defs/includedDocument" }
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "documentCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["issuedInvoices", "receivedInvoices", "expenses", "bankTransactions"],
      "properties": {
        "issuedInvoices": { "type": "integer", "minimum": 0 },
        "receivedInvoices": { "type": "integer", "minimum": 0 },
        "expenses": { "type": "integer", "minimum": 0 },
        "bankTransactions": { "type": "integer", "minimum": 0 },
        "attachments": { "type": "integer", "minimum": 0, "default": 0 }
      }
    },
    "exportFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "fileId", "sha256", "kind"],
      "properties": {
        "path": {
          "type": "string",
          "enum": [
            "vystavene_faktury/",
            "prijate_faktury/",
            "banka/",
            "pokladna/",
            "prehlady/",
            "dph/",
            "uctovny_export.xlsx",
            "manifest.json",
            "hashes.txt"
          ]
        },
        "fileId": { "type": "string", "format": "uuid" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "kind": {
          "type": "string",
          "enum": ["pdf", "xlsx", "csv", "json", "txt", "directory", "zip"]
        },
        "sourceEntityType": {
          "type": ["string", "null"],
          "enum": ["issued_invoice", "received_invoice", "expense", "bank_transaction", "vat_summary", "manifest", null]
        },
        "sourceEntityId": { "type": ["string", "null"], "format": "uuid" }
      }
    },
    "includedDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entityType", "entityId", "snapshotHash"],
      "properties": {
        "entityType": {
          "type": "string",
          "enum": ["issued_invoice", "received_invoice", "expense", "bank_transaction", "vat_summary"]
        },
        "entityId": { "type": "string", "format": "uuid" },
        "documentNumber": { "type": ["string", "null"], "maxLength": 80 },
        "snapshotHash": { "$ref": "#/$defs/sha256" },
        "changedAfterExport": { "type": "boolean", "default": false }
      }
    }
  }
}
