{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://uctovnik.local/schemas/audit-log.schema.json",
  "title": "Audit log",
  "type": "object",
  "additionalProperties": false,
  "required": ["auditEntry"],
  "properties": {
    "auditEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "organizationId",
        "actorId",
        "occurredAt",
        "entityType",
        "entityId",
        "action",
        "previousHash",
        "currentHash"
      ],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "organizationId": { "type": "string", "format": "uuid" },
        "actorId": { "type": ["string", "null"], "format": "uuid" },
        "actorType": {
          "type": "string",
          "enum": ["user", "system", "worker", "external"]
        },
        "occurredAt": { "type": "string", "format": "date-time" },
        "entityType": {
          "type": "string",
          "enum": [
            "issued_invoice",
            "invoice_email",
            "bank_payment_match",
            "expense",
            "accountant_export",
            "bank_account",
            "monthly_period",
            "document"
          ]
        },
        "entityId": { "type": "string", "format": "uuid" },
        "action": {
          "type": "string",
          "enum": [
            "invoice_issued",
            "invoice_sent",
            "payment_matched",
            "payment_unmatched",
            "expense_approved",
            "accountant_export_created",
            "iban_changed",
            "period_locked",
            "period_unlocked",
            "document_created",
            "sensitive_data_viewed"
          ]
        },
        "oldValue": { "type": ["object", "null"] },
        "newValue": { "type": ["object", "null"] },
        "ipAddress": { "type": ["string", "null"], "maxLength": 45 },
        "userAgent": { "type": ["string", "null"], "maxLength": 500 },
        "reason": { "type": ["string", "null"], "maxLength": 1000 },
        "previousHash": { "$ref": "#/$defs/sha256Nullable" },
        "currentHash": { "$ref": "#/$defs/sha256" }
      }
    },
    "integrityCheck": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["id", "organizationId", "checkedAt", "status"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "organizationId": { "type": "string", "format": "uuid" },
        "checkedAt": { "type": "string", "format": "date-time" },
        "status": {
          "type": "string",
          "enum": ["ok", "broken_chain", "missing_entry", "hash_mismatch"]
        },
        "firstBrokenAuditEntryId": { "type": ["string", "null"], "format": "uuid" },
        "details": { "type": ["string", "null"], "maxLength": 2000 }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "sha256Nullable": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
